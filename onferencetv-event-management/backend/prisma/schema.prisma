generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id                 String   @id @default(cuid())
  eventName          String
  eventDate          DateTime
  speakerName        String
  speakerDesignation String
  description        String?
  speakerIntro       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
